<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FreqScene.ConnectDialog"
        Width="360" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Title="FreqScene — Connect to Host">
    <StackPanel Margin="16" Spacing="8">
        <TextBlock Text="Host" />
        <TextBox x:Name="HostBox" PlaceholderText="192.168.1.20 or hostname" />
        <TextBlock Text="Port" />
        <TextBox x:Name="PortBox" />
        <TextBlock x:Name="ErrorText" Foreground="OrangeRed" IsVisible="False" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" IsCancel="True" Click="OnCancel" />
            <Button Content="Connect" IsDefault="True" Click="OnConnect" />
        </StackPanel>
    </StackPanel>
</Window>
