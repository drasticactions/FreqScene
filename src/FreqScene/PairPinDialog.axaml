<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FreqScene.PairPinDialog"
        Width="360" SizeToContent="Height"
        CanResize="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Title="FreqScene — Pairing Required">
    <StackPanel Margin="16" Spacing="8">
        <TextBlock x:Name="PromptText" TextWrapping="Wrap" />
        <TextBox x:Name="PinBox" PlaceholderText="123456" />
        <TextBlock x:Name="ErrorText" Foreground="OrangeRed" IsVisible="False" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" IsCancel="True" Click="OnCancel" />
            <Button x:Name="PairButton" Content="Pair" IsDefault="True" Click="OnPair" />
        </StackPanel>
    </StackPanel>
</Window>
